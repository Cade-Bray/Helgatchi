                      "group": "",
                      "groupIndex": 0,
                      "text": "Your Helgatchi will automatically scan for all nearby BT and WiFi signals. You can change this behavior in the device settings, disabling BT or WiFi Scanning.\n\nYour Helgatchi will sleep automatically. To wake it up, press and hold the Center button until the screen wakes.",
                      "textType": "literal",
                      "longMode": "WRAP",
                      "recolor": false
                    }
