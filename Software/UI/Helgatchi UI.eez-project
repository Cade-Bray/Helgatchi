                              "text_align": "CENTER"
                            }
                          }
                        }
                      },
                      "group": "",
                      "groupIndex": 0,
                      "text": "\"You have only three buttons on the Helgatchi. \\n\\n\" \n+ LVGL.LV_SYMBOL_LEFT + \" and \" + LVGL.LV_SYMBOL_RIGHT + \" are obvious: use them to go left/right or up/down.\\n\\n Press the center button to interact with selected content. Press and hold center to go back.\"\n",
                      "textType": "expression",
                      "longMode": "WRAP",
                      "recolor": false
                    }
                  ],
