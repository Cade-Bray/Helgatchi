# Admin-mode build secrets. Copy to `.env` (gitignored) and fill in real values;
# scripts/build_admin_secret.py loads it at build time. Shell env vars / CI
# secrets override the file. Missing either var hard-fails the build unless
# ALLOW_DEV_ADMIN_SECRET=1 is set (bakes insecure dev defaults + a compile warning).

# Frame-signing HMAC key — must be >= 32 bytes and CSPRNG-generated, NOT a
# passphrase (a single sniffed advert is a known message/tag pair). Generate:
#   openssl rand -hex 32
HELGATCHI_HMAC_SECRET=

# Admin unlock password. Never baked as plaintext — only its PBKDF2 digest is.
# Surrounding whitespace is stripped; internal characters are preserved.
HELGATCHI_ADMIN_PASSWORD=
